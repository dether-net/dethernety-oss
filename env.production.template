# =============================================================================
# Dethernety OSS Production Environment Configuration Template
# =============================================================================
# Copy this file to .env.production and customize for your deployment
#
# This template shows both backend and frontend environment variables
# and how they should be coordinated for production deployment.

# =============================================================================
# BACKEND CONFIGURATION (dt-ws)
# =============================================================================

# Application Settings
NODE_ENV=production
PORT=3000
LOG_LEVEL=log
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Neo4j Database Configuration
NEO4J_URI=neo4j+s://your-cluster.databases.neo4j.io:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-secure-password-here
NEO4J_DATABASE=production
NEO4J_ENCRYPTED=true
NEO4J_TRUST_CERT=false
NEO4J_MAX_POOL_SIZE=100

# Authentication (OIDC/OAuth2)
# This MUST match the issuer used in frontend configuration
OIDC_JKWS_URI=https://auth.yourdomain.com/.well-known/jwks.json

# GraphQL Security
GQL_QUERY_DEPTH_LIMIT=10
GQL_QUERY_COMPLEXITY_LIMIT=1000
GQL_ENABLE_SUBSCRIPTIONS=true

# Module Registry (Production Security)
ALLOWED_MODULES=dethermine-module,dt-built-in-module
ENABLE_MODULE_HOT_RELOAD=false
CUSTOM_MODULES_PATH=custom_modules

# Performance & Caching
TEMPLATE_CACHE_SIZE=500
TEMPLATE_CACHE_TTL_MS=600000
ANALYSIS_CACHE_SIZE=200
ANALYSIS_CACHE_TTL_MS=1200000

# Monitoring
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=30000
STATISTICS_RETENTION_HOURS=48

# =============================================================================
# FRONTEND CONFIGURATION (dt-ui) - BUILD TIME ONLY
# =============================================================================
# These variables are used during the Docker build process
# They are embedded into the built frontend assets

# OIDC Configuration (must match backend OIDC_JKWS_URI)
OIDC_ISSUER=https://auth.yourdomain.com
OIDC_CLIENT_ID=your-production-client-id
OIDC_REDIRECT_URI=https://yourdomain.com/auth/callback

# API Configuration (relative URLs for same-domain deployment)
GRAPHQL_URL=/graphql
GRAPHQL_WS_URL=  # Leave empty for auto-detection
API_BASE_URL=

# Application Configuration
APP_BASE_URL=/
APP_URL=https://yourdomain.com

# Feature Flags
DEBUG_AUTH=false
ENABLE_DEV_TOOLS=false

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# 1. OIDC Coordination:
#    - Backend OIDC_JKWS_URI should be: https://auth.yourdomain.com/.well-known/jwks.json
#    - Frontend VITE_OIDC_ISSUER should be: https://auth.yourdomain.com
#    - Both must use the same authentication provider

# 2. CORS Configuration:
#    - ALLOWED_ORIGINS should include your domain
#    - Frontend will be served from the same domain as backend

# 3. Database Security:
#    - Use encrypted connections (NEO4J_ENCRYPTED=true)
#    - Use strong passwords
#    - Consider network-level security

# 4. Module Security:
#    - Explicitly list allowed modules in ALLOWED_MODULES
#    - Disable hot reload in production (ENABLE_MODULE_HOT_RELOAD=false)

# 5. Frontend URLs:
#    - Use relative URLs (/graphql) since frontend is served by backend
#    - WebSocket URL auto-detection handles wss:// protocol
