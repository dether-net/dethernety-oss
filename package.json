{
  "name": "dethernety",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:production": "turbo build:production",
    "build:docker": "turbo build:docker",
    "docker:build": "docker build -f Dockerfile.production -t dethernety:latest .",
    "docker:run": "docker run --env-file .env.production -p 3000:3000 dethernety:latest",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "m-cleanup": "turbo run m-cleanup",
    "m-ingest": "turbo run m-ingest",
    "parsetest": "turbo run parsetest",
    "docs:api": "node scripts/generate-api-docs.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "neo4j-driver": "^5.28.2",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "turbo": "^2.8.16",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.13.2",
  "pnpm": {
    "overrides": {
      "zod": "4.3.6",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "multer": ">=2.1.0",
      "lodash": ">=4.17.23",
      "ajv@^8.0.0": ">=8.18.0",
      "minimatch@>=9.0.0": ">=9.0.7"
    }
  }
}
