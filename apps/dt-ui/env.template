# Dethernety Frontend Environment Configuration
# Copy this file to .env.local for development or .env.production for production

# =============================================================================
# OIDC Authentication Configuration
# =============================================================================
# These must be coordinated with the backend OIDC_JKWS_URI setting

# Development Environment (HTTP)
OIDC_ISSUER=http://dethernety.corp:8080
OIDC_CLIENT_ID=your-development-client-id
OIDC_REDIRECT_URI=http://dethernety.corp:3005/auth/callback

# OIDC Provider (optional - auto-detected from issuer URL if not set)
# Options: cognito, zitadel, auth0, keycloak, generic
# Each provider has different OAuth2 endpoint paths and claim formats
# OIDC_PROVIDER=cognito

# Production Environment (HTTPS) - uncomment and modify for production
# OIDC_ISSUER=https://auth.yourdomain.com
# OIDC_CLIENT_ID=your-production-client-id
# OIDC_REDIRECT_URI=https://yourdomain.com/auth/callback

# AWS Cognito Example:
# OIDC_ISSUER=https://cognito-idp.eu-central-1.amazonaws.com/eu-central-1_XXXXXXXX
# OIDC_CLIENT_ID=your-cognito-app-client-id
# OIDC_REDIRECT_URI=https://yourdomain.com/auth/callback
# OIDC_PROVIDER=cognito

# =============================================================================
# API Configuration
# =============================================================================
# In production, these should be relative URLs or match the deployment domain

# Development - explicit URLs for proxy setup
API_BASE_URL=http://localhost:3003
GRAPHQL_URL=http://localhost:3003/graphql

# Subscription Transport: 'sse' (default) or 'ws' (WebSocket)
# SSE is simpler (works through proxies, no sticky sessions needed)
# WebSocket provides lower latency but requires additional infrastructure
SUBSCRIPTION_TRANSPORT=sse

# WebSocket URL (only used when SUBSCRIPTION_TRANSPORT=ws)
GRAPHQL_WS_URL=ws://localhost:3003/graphql

# Production - relative URLs (served from same domain as backend)
# API_BASE_URL=
# GRAPHQL_URL=/graphql
# GRAPHQL_WS_URL=wss://yourdomain.com/graphql

# =============================================================================
# Application Configuration
# =============================================================================
# Base URL for the application (useful for subdirectory deployments)
APP_BASE_URL=/

# Application URL (used for OIDC redirects)
APP_URL=http://dethernety.corp:3005

# =============================================================================
# Feature Flags & Debug
# =============================================================================
# Enable debug logging in development
DEBUG_AUTH=true

# Enable development features
ENABLE_DEV_TOOLS=true
