{
  "name": "@dether.net/dethereal",
  "version": "0.1.16",
  "description": "Dethereal - Claude Code plugin for AI-guided threat modeling with Dethernety",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dethereal": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "tsc -w",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills",
    "agents",
    "hooks",
    "docs",
    ".claude-plugin",
    ".mcp.json",
    "settings.json",
    "scripts",
    "CLAUDE.md"
  ],
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cross-fetch": "^4.0.0",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "open": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@dethernety/dt-core": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.0.0"
  }
}
