{
  "name": "dethernety-module",
  "type": "module",
  "version": "0.1.0",
  "main": "dist/dethernety/dethernety-module/DethernetyModule.js",
  "types": "dist/dethernety/dethernety-module/DethernetyModule.d.ts",
  "scripts": {
    "build": "pnpm build:ts && pnpm build:package",
    "build:ts": "tsc",
