    "@nestjs/common": "^11.1.17",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "json-logic-js": "^2.0.5",
    "neo4j-driver": "^5.28.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0"
  }
}
